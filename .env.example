# ─── Email (Amazon SES) ──────────────────────────────────────────────────────
# The address SES sends FROM. Must be verified in SES before deploying.
# Verify a single address: AWS Console → SES → Verified Identities → Create Identity
# Verify a whole domain (recommended): add the CNAME/TXT records SES gives you.
FROM_EMAIL=hello@yourdomain.com

# Your personal/team email for new-signup notifications.
# Also needs to be SES-verified while you're in sandbox mode.
NOTIFY_EMAIL=you@yourdomain.com

# ─── Broadcast endpoint protection ───────────────────────────────────────────
# A long random string that protects the /broadcast endpoint.
# Generate one: openssl rand -hex 32
BROADCAST_API_KEY=replace_with_a_long_random_string
